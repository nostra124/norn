<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN"
  "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<!-- Per-user agent: install to ~/Library/LaunchAgents/io.norn.nornd.plist
     and `launchctl load -w` it (Homebrew: `brew services start norn`).
     Identity = ssh-agent if available, else ~/.ssh/id_ed25519. -->
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>io.norn.nornd</string>

  <key>ProgramArguments</key>
  <array>
    <string>/usr/local/bin/nornd</string>
    <string>--foreground</string>
  </array>

  <!-- Socket activation under the user's run dir. -->
  <key>Sockets</key>
  <dict>
    <key>Listener</key>
    <dict>
      <key>SockPathName</key>
      <string>${HOME}/Library/Caches/io.norn/nornd.sock</string>
      <key>SockPathMode</key>
      <integer>384</integer> <!-- 0600 -->
    </dict>
  </dict>

  <key>KeepAlive</key>
  <true/>
  <key>RunAtLoad</key>
  <true/>
</dict>
</plist>
